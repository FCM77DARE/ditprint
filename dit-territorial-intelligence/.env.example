# ─── CRITICAL (required at startup) ──────────────────────────────────────────

# JWT signing secret. MUST be at least 32 characters (server refuses to start otherwise).
# Generate a strong one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# MySQL/TiDB connection string. Required in production; optional in development.
# Format: mysql://user:password@host:port/database
DATABASE_URL=

# ─── Manus Forge (LLM gateway) ───────────────────────────────────────────────
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ─── OAuth (optional — Manus login) ──────────────────────────────────────────
VITE_APP_ID=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# ─── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
